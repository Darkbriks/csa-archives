---
import { getCollection } from 'astro:content';
import VaisseauLayout from '../../layouts/VaisseauLayout.astro';
export async function getStaticPaths() {
  const items = await getCollection('vaisseaux');
  const missions = await getCollection('missions');
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item, flights: missions.filter((m) => m.data.charge?.slug === item.slug) },
  }));
}
const { item, flights } = Astro.props;
const { Content } = await item.render();
---
<VaisseauLayout item={item} flights={flights}><Content /></VaisseauLayout>
